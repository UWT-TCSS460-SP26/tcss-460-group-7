generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           Int       @id @default(autoincrement())
  subjectId    String    @unique
  username     String    @unique
  email        String    @unique
  display_name String?
  role         Int       @default(2)
  reviews      Review[]
  ratings      Rating[]
  issues       Issue[]


  @@map("users")
}


model Review {
  id        Int      @id @default(autoincrement())
  authorId  Int?     // foreign key to User, nullable to allow for reviews without an author
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull) // RELATIONSHIP USER 1 : N REVIEW
  content   String?
  createdAt DateTime @default(now())
  header    String?
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  title_id  Int

  @@map("reviews")
}

model Rating {
  id       Int   @id @default(autoincrement())
  authorId Int?
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  rating   Int
  title_id Int

  @@unique([authorId, title_id])
  @@map("ratings")
}

model Issue {
  id        Int      @id @default(autoincrement())
  authorId  Int?    
  author    User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
  @@map("issues")
}