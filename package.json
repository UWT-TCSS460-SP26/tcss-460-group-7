{
  "name": "tcss460-group-project-backend",
  "version": "0.0.0",
  "description": "TCSS 460 Group-7 Project — Express + TypeScript API",
  "author": "",
  "license": "ISC",
  "main": "dist/index.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint --config eslint.config.mjs .",
    "lint:fix": "eslint --config eslint.config.mjs --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:db": "prisma studio",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "npx prisma studio",
    "prisma:reset": "npx prisma migrate reset",
    "db:setup": "docker compose up -d db && npx prisma migrate dev && npx prisma generate && tsx prisma/seed.ts",
    "status": "jest -- tests/heartbeat.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@scalar/express-api-reference": "^0.9.12",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "jwks-rsa": "^4.0.1",
    "pg": "^8.16.0",
    "typescript": "~5.9",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "install": "^0.13.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "npm": "^11.12.1",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0"
  }
}
